{
  "hosting": {
    "site": "kifaz-mittagsplaner",
    "public": ".",
    "ignore": [
      "firebase.json",
      ".firebaserc",
      "**/.*",
      "**/node_modules/**",
      "README.md",
      "firebase-rules.json"
    ],
    "headers": [
      { "source": "**", "headers": [ { "key": "Cache-Control", "value": "no-cache" } ] },
      { "source": "**/*.woff2", "headers": [ { "key": "Cache-Control", "value": "public, max-age=604800, immutable" } ] }
    ]
  }
}
